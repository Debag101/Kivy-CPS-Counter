#:kivy 2.3.1
RootWindow:

<RootWindow>:

    orientation: "vertical"
    padding: "40dp"
    spacing:"15dp"
    # main button design
    AnchorLayout:
        Button:
            #accessing the avg_cps StringProperty
            
            text: root.button_text
            size_hint: 0.8, 0.6
            pos_hint: {"center_x": 0.5}
            font_name: "../fonts/Minecraft.ttf"
            font_size: "40dp"

            on_press: root.callback()

            color: 0, 0, 1, 1
            background_color: 1, 0, 0, 1

            disabled: root.button_disabled

       
    

    BoxLayout:

        #CPS Text
        Label:
            text: "CPS : "
            font_name: "../fonts/Minecraft.ttf"
            font_size: "40dp"
            #pos_hint: {"center_y": 0.45}
            size_hint: 1, 0.5

        #Count
        Label:
            text: root.cps
            font_name: "../fonts/Minecraft.ttf"
            font_size: "40dp"
            #pos_hint: {"center_y": 0.45}
            size_hint: 1, 0.5

    Label:
        text:root.final_score
        color: 1, 1, 0, 1
        font_name: "../fonts/Minecraft.ttf"
        font_size: "40dp"
        size_hint: 1, 0.4


    BoxLayout:
        Slider:
            padding : "40dp"
            min: 0
            max : 30
            value : 5
            on_value : root.on_slide(self)
        
        Label:
            font_name: "../fonts/Minecraft.ttf"
            font_size : "35dp"
            text: root.slider_timer


